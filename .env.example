DATABASE_URL=postgresql://neondb_owner:npg_lKijJd15SITE@ep-fragrant-morning-atbuymy4.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Random long string used to salt hashed IPs (see lib/ids.ts). Generate one
# with: openssl rand -hex 32
IP_HASH_SALT=change-this-to-a-random-string-in-production

# OpenAI API key for content moderation (lib/validation.ts).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Cloudflare Turnstile keys for bot protection on quiz creation.
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis for production rate limiting (lib/rate-limit.ts).
# https://console.upstash.com
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Resend API key + admin email for report notifications (lib/notify.ts).
# https://resend.com/api-keys
RESEND_API_KEY=
ADMIN_EMAIL=
